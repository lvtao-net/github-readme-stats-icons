# GitHub Personal Access Tokens (comma-separated for multiple tokens)
# Get yours at: https://github.com/settings/tokens
# Required scopes: read:user, repo
# Multiple tokens example: PAT_1=token1,token2,token3
PAT_1=your_github_token_here

# Cache duration in seconds (min: 3600=1hour, max: 86400=24hours, default: 86400)
# Production: 86400 (24 hours)
# Development: 3600 (1 hour)
CACHE_SECONDS=86400

# Debug mode (true/false)
# Debug mode disables cache for easier development
DEBUG=false

# Rate limiting: max requests per user per hour (default: 30)
RATE_LIMIT_PER_USER=30

# Server port
PORT=8080

# Enable fetching all starred repositories for accurate star counts
FETCH_MULTI_PAGE_STARS=false

# Optional: Whitelist of allowed usernames (comma-separated)
# WHITELIST=user1,user2,user3

# Optional: Whitelist of allowed gist IDs (comma-separated)
# GIST_WHITELIST=gist1,gist2,gist3

# Optional: Repositories to exclude from stats (comma-separated)
# EXCLUDE_REPO=repo1,repo2,repo3
